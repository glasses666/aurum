# Aurum local development placeholder
# Do not put live wallet keys or real trading credentials in this repository.

POLYMARKET_CLOB_HOST=https://clob.polymarket.com
AURUM_MODE=paper
AURUM_DUEL_MODE=review_only

# First contest window: Bitcoin-only, paper-only. Bots may later run at 5s+ intervals.
AURUM_DUEL_UNIVERSE=bitcoin
AURUM_DUEL_SEARCH_QUERY=bitcoin
AURUM_FIRST_CONTEST_DAYS=7
AURUM_BOT_MIN_INTERVAL_SEC=5
AURUM_BOT_DEFAULT_INTERVAL_SEC=15

# Polymarket-like paper execution rules.
# Current paper fills are immediate taker fills: fee = shares * fee_rate * price * (1 - price).
# For the first BTC contest this uses the Crypto taker fee rate from Polymarket docs.
AURUM_PAPER_TRADE_ROLE=taker
AURUM_POLYMARKET_FEE_MODE=polymarket_docs_2026
AURUM_POLY_MIN_ORDER_USDC=5

# Optional DeepSeek paper-agent duel configuration.
# Never commit real keys; copy this file to .env on the target host and chmod 600 it.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_MODEL=deepseek-v4-flash

# DeepSeek operator controls: default is review-only.
# DS can propose paper decisions with --no-apply, but cannot alter the paper wallet unless BOTH gates are changed.
AURUM_DEEPSEEK_ALLOW_PAPER_APPLY=false
AURUM_DEEPSEEK_OPERATOR_CONFIRM=

# Runner-enforced DS caps; the model cannot override these values.
AURUM_DEEPSEEK_MAX_ORDERS=2
AURUM_DEEPSEEK_MAX_NOTIONAL=45
AURUM_DEEPSEEK_TEMPERATURE=0.2
AURUM_DEEPSEEK_THINKING=enabled
AURUM_DEEPSEEK_REASONING_EFFORT=high
AURUM_DEEPSEEK_STRUCTURED_RETRY=true

# Public transparency dashboard. Static output only; do not publish secrets.
AURUM_PUBLIC_DASHBOARD_DIR=/opt/aurum/public/dashboard

# Configurable slow strategy review. Default cadence is about 30 minutes.
AURUM_REVIEW_MODEL=deepseek-v4-pro
AURUM_REVIEW_THINKING=disabled
AURUM_REVIEW_REASONING_EFFORT=high
AURUM_REVIEW_CADENCE_SECONDS=1800
AURUM_REVIEW_LIMIT_TICKS=24
AURUM_RULE_AUTO_PROMOTE=false
AURUM_RULE_OPERATOR_CONFIRM=
